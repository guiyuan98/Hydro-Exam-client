{
  "name": "hydro-oj-exam-shell",
  "version": "0.1.0",
  "description": "Hydro OJ secure desktop shell with local OI editor",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "electron . --no-proctor",
    "start:tools": "electron . --tools",
    "start:dev-tools": "electron . --no-proctor --tools",
    "dist:win": "electron-builder --win --dir --x64"
  },
  "build": {
    "appId": "io.github.guiyuan98.hydro-exam-client",
    "productName": "Hydro Exam Client",
    "files": [
      "src/**/*",
      "gyoj-shell.json",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../.qt/Tools/mingw1310_64",
        "to": "tools/mingw"
      }
    ],
    "win": {}
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.0.12"
  }
}
